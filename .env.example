# SEC EDGAR User-Agent — 형식: "이름 email@domain.com" (Spec §5.4)
SEC_USER_AGENT="Your Name your_email@example.com"

# OpenFIGI API key (선택, 키 없으면 25 req/min, 키 있으면 250 req/min)
OPENFIGI_API_KEY=""

# DuckDB 경로 (기본값 data/13f.duckdb)
DUCKDB_PATH="data/13f.duckdb"

# Google Gemini API (Phase 4 분기 리포트 요약 + 시그널 해석 보조)
# 키는 https://aistudio.google.com/apikey 에서 발급
GOOGLE_API_KEY=""
GOOGLE_MODEL="gemini-3-flash-preview"
# Gemini thinking on/off (기본 true). false로 두면 thinkingBudget=0 강제 — 토큰·지연 감소, 품질 미세 ↓
GEMINI_THINKING="true"
